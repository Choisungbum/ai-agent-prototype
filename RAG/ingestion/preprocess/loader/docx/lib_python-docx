from docx import Document
import json

docx_path = "/app/ingestion/testfile/docx/(클라우드)검색시스템_운영자메뉴얼-한국소방안전원 KFSI 종합정보시스템 구축 용역.docx"

def load_docx(path):
    doc = Document(path)

    sections = []
    current = {"title": None, "texts": []}

    for p in doc.paragraphs:
        text = p.text.strip()
        if not text:
            continue

        style = p.style.name

        # 제목 판별 (Heading 기반)
        if style.startswith("Heading"):
            if current["texts"]:
                sections.append(current)
            current = {
                "title": text,
                "texts": []
            }
        else:
            current["texts"].append(text)

    if current["texts"]:
        sections.append(current)

    return sections

jsondata = load_docx(docx_path)
print(jsondata)
with open(f"file.json", "w", encoding="utf-8") as f:
        json.dump(jsondata, f, ensure_ascii=False, indent=2)